{
  "manifest_version": 3,
  "name": "YouTube Floating PiP",
  "version": "0.1.0",
  "description": "Open the current YouTube video in Chrome's detached Picture-in-Picture window.",
  "permissions": ["activeTab", "scripting"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Toggle YouTube PiP"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  }
}
